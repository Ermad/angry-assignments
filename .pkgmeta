package-as: AngryAssignments

enable-nolib-creation: yes

externals:
  libs/Ace3:
    url: https://github.com/WoWUIDev/Ace3
    tag: latest
  libs/LibDeflate:
    url: https://github.com/SafeteeWoW/LibDeflate
    tag: latest
  libs/LibWindow-1.1:
    url: https://github.com/wowace-clone/LibWindow-1.1
    tag: latest
  libs/LibSharedMedia-3.0:
    url: https://github.com/wowace-clone/LibSharedMedia-3.0
    tag: latest
  libs/AceGUI-3.0-SharedMediaWidgets:
    url: https://github.com/wowace-clone/AceGUI-3.0-SharedMediaWidgets
    tag: latest
  libs/LibDataBroker-1.1:
    url: https://github.com/tekkub/libdatabroker-1-1
    tag: latest
  libs/LibDBIcon-1.0:
    url: https://github.com/kaldown/LibDBIcon-1.0
    tag: latest

ignore:
  - dist
  - package.sh
  - libs.sh
  - Makefile
  - .luacheckrc
  - .gitignore
  - .gitattributes
  - .editorconfig
  - .github
  - README.md
  - CHANGELOG.txt
  - libs/Ace3/tests
  - libs/LibDeflate/docs
  - libs/LibDeflate/examples
  - libs/LibDeflate/*.rockspec
  - libs/LibSharedMedia-3.0/LibStub
  - libs/LibSharedMedia-3.0/CallbackHandler-1.0
  - libs/LibSharedMedia-3.0/tests
